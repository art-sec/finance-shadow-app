# ⚠️ ENVIRONMENT VARIABLES - TEMPLATE
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite .env.local no Git - está no .gitignore para proteção

# ===== FIREBASE CONFIGURATION =====
# Obtenha estes valores em: https://console.firebase.google.com
# Project Settings (engrenagem) > Web App > firebaseConfig

# API Key - Identificador público do seu projeto Firebase
# ℹ️ Safe to expose: Protegido por Firebase Security Rules
# ❌ Não é uma senha: Use Security Rules para proteger dados
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here

# Auth Domain - Domínio para autenticação e segurança CORS
# Formato: your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Project ID - Identificador único do seu projeto Firebase
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Storage Bucket - Para armazenar arquivos no Cloud Storage
# Formato: your_project.appspot.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Messaging Sender ID - Para Cloud Messaging (push notifications)
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# App ID - Identificador único da aplicação web
# Formato: 1:123456789:web:abcdef1234567890
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_app_id:web:your_web_id

# ===== CONFIGURAÇÕES OPCIONAIS =====

# Ambiente de desenvolvimento
# NODE_ENV=development

# Firebase Emulator (para testes locais)
# FIREBASE_EMULATOR_HOST=localhost:9099

# URLs Customizadas
# EXPO_PUBLIC_API_URL=https://api.seu-dominio.com
# EXPO_PUBLIC_APP_URL=https://seu-dominio.com

# Feature Flags
# EXPO_PUBLIC_ENABLE_DEBUG_MODE=false
# EXPO_PUBLIC_ENABLE_ANALYTICS=true

# ===== ⚠️ SEGURANÇA - O QUE NÃO COLOCAR AQUI =====
#
# ❌ NÃO adicione Firebase Admin SDK credentials
# ❌ NÃO adicione chaves de API backend/privadas
# ❌ NÃO adicione senhas de usuários
# ❌ NÃO adicione tokens JWT ou de sessão
# ❌ NÃO adicione dados de acesso ao banco de dados
# ❌ NÃO adicione credenciais de cartão de crédito
# ❌ NÃ adicione qualquer secret que começa com "secret_"
#
# Para informações privadas, use:
# 1. Variáveis de Ambiente do Vercel (produção)
# 2. Backend server com variáveis privadas (mais seguro)
# 3. GitHub Secrets para CI/CD Actions
# 4. AWS Secrets Manager / Google Secret Manager
#

# ===== COMO CONFIGURAR NO VERCEL =====
#
# 1. Vá para: https://vercel.com/dashboard
# 2. Clique no seu projeto
# 3. Project Settings > Environment Variables
# 4. Adicione cada variável:
#    Name: EXPO_PUBLIC_FIREBASE_API_KEY
#    Value: seu_valor_aqui
# 5. Marque os ambientes: Production, Preview, Development
# 6. Clique "Save"
# 7. Redeploy o projeto para usar as novas variáveis
#

# ===== DESENVOLVIMENTO LOCAL =====
#
# 1. Copie este arquivo:
#    cp .env.example .env.local
# 2. Edite .env.local com seus valores reais
# 3. Execute: npm run web
# 4. As variáveis serão carregadas automaticamente
#
# ❌ NUNCA commite .env.local
# ✅ .env.local está no .gitignore
#

